{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "infra/monitoring/railway/vector/Dockerfile",
    "buildContext": "infra/monitoring"
  },
  "deploy": {
    "startCommand": "vector --config-yaml /etc/vector/vector.yaml",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
